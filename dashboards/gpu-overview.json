      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "title": "GPU Count",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "count(DCGM_FI_DEV_GPU_UTIL{job=\"dcgm\"})",
          "refId": "A"
