{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview — All Containers",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Container" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Memory" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Memory %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Net In" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Net Out" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 100 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "CPU %", "desc": true }]
      },
      "title": "Container Resource Usage",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #cpu": "CPU %",
              "Value #mem": "Memory",
              "Value #mempct": "Memory %",
              "Value #netin": "Net In",
              "Value #netout": "Net Out",
              "name": "Container"
            },
            "excludeByName": {
              "Time": true
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\".+\"}[$__rate_interval])) * 100",
          "format": "table",
          "instant": true,
          "refId": "cpu"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "container_memory_usage_bytes{name=~\".+\"}",
          "format": "table",
          "instant": true,
          "refId": "mem"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "container_memory_usage_bytes{name=~\".+\"} / container_spec_memory_limit_bytes{name=~\".+\"} * 100 > 0",
          "format": "table",
          "instant": true,
          "refId": "mempct"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\".+\"}[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "refId": "netin"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name=~\".+\"}[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "refId": "netout"
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Selected Container — $container",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "CPU Usage",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"$container\"}[$__rate_interval])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Memory Usage",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "container_memory_usage_bytes{name=~\"$container\"}",
          "legendFormat": "Used — {{name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "container_spec_memory_limit_bytes{name=~\"$container\"} > 0",
          "legendFormat": "Limit — {{name}}",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Network I/O",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\"$container\"}[$__rate_interval]))",
          "legendFormat": "In — {{name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name=~\"$container\"}[$__rate_interval]))",
          "legendFormat": "Out — {{name}}",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 18 },
      "id": 5,
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "title": "Container Logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "{job=\"docker\", container=~\"$container\"}",
          "refId": "A"
        }
      ],
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["docker", "containers"],
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": {},
        "datasource": { "type": "prometheus", "uid": "" },
        "definition": "label_values(container_cpu_usage_seconds_total, name)",
        "includeAll": true,
        "multi": false,
        "name": "container",
        "query": {
          "query": "label_values(container_cpu_usage_seconds_total, name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Docker Containers",
  "uid": "docker-containers",
  "version": 1
}
